generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// メモテーブル
model Memo {
  id             Int       @id @default(autoincrement())
  title          String
  bodyMd         String
  parentMemoId   Int?
  labels         String    // JSON配列として保存
  metaJson       String?   // JSON
  isBookmarked   Boolean   @default(false)
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // リレーション
  parentMemo     Memo?        @relation("MemoHierarchy", fields: [parentMemoId], references: [id], onDelete: SetNull)
  childMemos     Memo[]       @relation("MemoHierarchy")
  tasksFromMemo  Task[]       @relation("TaskSourceMemo")
  projectItems   ProjectItem[]

  @@index([parentMemoId])
  @@index([isDeleted])
  @@index([createdAt])
}

// タスクステータス列挙型
enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

// タスクテーブル
model Task {
  id               Int         @id @default(autoincrement())
  title            String
  bodyMd           String?
  url              String?
  state            TaskStatus  @default(OPEN)
  scheduledOn      DateTime?
  estimatedMinutes Int?
  priority         Int?
  labels           String      // JSON配列として保存
  metaJson         String?     // JSON
  sourceMemoId     Int?
  isDeleted        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  closedAt         DateTime?

  // リレーション
  sourceMemo       Memo?          @relation("TaskSourceMemo", fields: [sourceMemoId], references: [id], onDelete: SetNull)
  projectItems     ProjectItem[]

  @@index([sourceMemoId])
  @@index([state])
  @@index([isDeleted])
  @@index([scheduledOn])
  @@index([createdAt])
}

// プロジェクトテーブル
model Project {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  isDefault   Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // リレーション
  statuses    ProjectStatus[]
  items       ProjectItem[]

  @@index([isDefault])
  @@index([isDeleted])
}

// プロジェクトステータステーブル
model ProjectStatus {
  id          Int       @id @default(autoincrement())
  projectId   Int
  name        String
  description String?
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // リレーション
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       ProjectItem[]

  @@unique([projectId, name])
  @@index([projectId, order])
}

// アイテム種別列挙型
enum ItemKind {
  MEMO
  TASK
}

// プロジェクトアイテムテーブル
model ProjectItem {
  id              Int       @id @default(autoincrement())
  projectId       Int
  projectStatusId Int
  itemKind        ItemKind
  itemId          Int
  position        Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // リレーション
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectStatus   ProjectStatus @relation(fields: [projectStatusId], references: [id], onDelete: Cascade)
  memo            Memo?         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  task            Task?         @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([projectId, itemKind, itemId])
  @@index([projectId, projectStatusId])
  @@index([itemKind, itemId])
}
