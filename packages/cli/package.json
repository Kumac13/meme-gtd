{
  "name": "meme-gtd-cli",
  "version": "0.39.3",
  "private": false,
  "type": "module",
  "description": "CLI entry point for meme-gtd",
  "bin": {
    "mgtd": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "test": "pnpm run -s build && node --test test/*.test.js test/commands/task/*.test.js test/commands/memo/*.test.js test/commands/project/*.test.js test/commands/db/*.test.js"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "fs-extra": "^11.2.0",
    "meme-gtd-config": "workspace:*",
    "meme-gtd-core": "workspace:*",
    "meme-gtd-db": "workspace:*",
    "meme-gtd-logger": "workspace:*",
    "meme-gtd-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.15.0",
    "typescript": "^5.5.4"
  },
  "oclif": {
    "bin": "mgtd",
    "commands": "./dist/commands"
  }
}
