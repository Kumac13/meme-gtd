{
  "name": "meme-gtd-cli",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "description": "CLI entry point for meme-gtd",
  "bin": {
    "mgtd": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "pnpm run -s build && node --test test/*.test.js test/commands/task/*.test.js"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "better-sqlite3": "^9.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "json5": "^2.2.3",
    "kleur": "^4.1.5",
    "zod": "^3.23.8",
    "meme-gtd-config": "workspace:*",
    "meme-gtd-core": "workspace:*",
    "meme-gtd-db": "workspace:*",
    "meme-gtd-logger": "workspace:*",
    "meme-gtd-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/json5": "^0.0.30",
    "@types/better-sqlite3": "^7.6.8",
    "eslint": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "rimraf": "^5.0.7",
    "tsx": "^4.15.0",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "oclif": {
    "bin": "mgtd",
    "commands": "./dist/commands"
  }
}
