# Development Environment Configuration for meme-gtd-api

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database
# Leave empty to use default config path (~/.config/mgtd/context.json)
DB_PATH=

# CORS Configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=debug
NODE_ENV=development
