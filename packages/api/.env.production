# Production Environment Configuration for meme-gtd-api

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database
# Specify absolute path to production database
DB_PATH=/var/lib/mgtd/issues.db

# CORS Configuration (comma-separated origins)
# Set to specific origins or use * for any origin (not recommended)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Logging
LOG_LEVEL=info
NODE_ENV=production
