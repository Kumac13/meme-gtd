{
  "name": "meme-gtd-api",
  "version": "0.15.0",
  "description": "HTTP API server for meme-gtd CLI operations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "cd ../.. && DB_PATH=./test-data/test.db PORT=3001 tsx packages/api/src/index.ts",
    "start": "cd ../.. && node packages/api/dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "test:watch": "tsx --test --watch test/**/*.test.ts",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:validate": "redocly lint docs/api/openapi.yaml",
    "openapi:bundle": "redocly bundle docs/api/openapi.yaml -o docs/api/openapi.bundle.yaml",
    "sdk:generate-types": "./scripts/generate-sdk-types.sh"
  },
  "keywords": [
    "gtd",
    "api",
    "fastify",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "10.0.1",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.0",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "meme-gtd-config": "workspace:*",
    "meme-gtd-core": "workspace:*",
    "meme-gtd-db": "workspace:*",
    "meme-gtd-shared": "workspace:*",
    "pino": "^9.5.0",
    "yaml": "^2.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@redocly/cli": "^1.25.14",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.9.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "zod-to-json-schema": "^3.24.6"
  }
}
