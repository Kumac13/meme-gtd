{
  "name": "meme-gtd",
  "version": "0.47.0",
  "private": true,
  "description": "CLI toolkit for meme-gtd (init + memo commands)",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm --filter meme-gtd-shared build && pnpm build:web && pnpm -r build",
    "build:web": "pnpm --filter meme-gtd-web build",
    "dev:web": "pnpm --filter meme-gtd-web dev",
    "server:start": "pnpm --filter meme-gtd-api start",
    "server:dev": "pnpm --filter meme-gtd-api dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev": "pnpm --filter meme-gtd-cli dev",
    "format": "pnpm -r format",
    "mgtd": "pnpm --filter meme-gtd-cli exec node dist/index.js",
    "mgtd:test": "MGTD_ENV=test DB_PATH=$PWD/test-data/test.db MGTD_CONFIG_PATH=$PWD/test-data/context.json pnpm mgtd",
    "mgtd:dev": "pnpm --filter meme-gtd-cli exec tsx ./src/index.ts",
    "bootstrap": "pnpm install && pnpm build",
    "mgtd:install": "node ./scripts/install-cli.mjs",
    "mgtd:pack": "node ./scripts/package-cli.mjs",
    "knip": "knip"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "better-sqlite3": "^9.6.0",
    "knip": "^5.71.0"
  }
}
